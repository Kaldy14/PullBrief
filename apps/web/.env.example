# App URL used by Better Auth redirects/cookies.
NEXT_PUBLIC_APP_URL=http://localhost:3000
BETTER_AUTH_URL=http://localhost:3000
# Generate with: openssl rand -base64 32
BETTER_AUTH_SECRET=

# Postgres. Start local DB with: docker compose up -d postgres
DATABASE_URL=postgresql://pullbrief:pullbrief@localhost:5432/pullbrief

# Internal account seeding. Public sign-up stays disabled unless explicitly overridden.
PULLBRIEF_SEED_EMAIL=
PULLBRIEF_SEED_PASSWORD=
PULLBRIEF_SEED_NAME=
PULLBRIEF_SEED_TENANT_NAME=PullBrief Internal
PULLBRIEF_SEED_TENANT_SLUG=pullbrief-internal
PULLBRIEF_SEED_ROLE=admin
# PULLBRIEF_ENABLE_PUBLIC_SIGNUP=false

# GitHub App integration. Configure these from the GitHub App settings page.
# Setup URL:    http://localhost:3000/api/github/setup
# Webhook URL:  http://localhost:3000/api/github/webhooks
# Callback URL: http://localhost:3000/api/github/oauth/callback
GITHUB_APP_ID=
GITHUB_APP_SLUG=
# Paste the PEM contents; escaped \n newlines are accepted.
GITHUB_APP_PRIVATE_KEY=
GITHUB_WEBHOOK_SECRET=
# Required for setup verification.
GITHUB_APP_CLIENT_ID=
GITHUB_APP_CLIENT_SECRET=
# Comma-separated GitHub org/user accounts this deployment may link. Required in production.
PULLBRIEF_ALLOWED_GITHUB_ACCOUNTS=
# Local-only bypass for setup verification; do not use in shared/prod deployments.
# PULLBRIEF_SKIP_GITHUB_USER_INSTALL_VERIFICATION=true
# In production with a configured GitHub App, reports require an installed/enabled repo by default.
# PULLBRIEF_REQUIRE_GITHUB_APP=true
# Dev fallback for public repos / PAT-based smoke tests. Keep false in shared/prod deployments.
# Requires BOTH flags and a localhost app URL; production still always fails closed.
PULLBRIEF_ALLOW_GITHUB_TOKEN_FALLBACK=false
PULLBRIEF_CONFIRM_LOCALHOST_ONLY_FALLBACK=false
PULLBRIEF_GITHUB_TOKEN=

# Optional GitHub Enterprise or proxy settings.
PULLBRIEF_GITHUB_HOST=github.com
PULLBRIEF_GITHUB_API_BASE_URL=https://api.github.com
PULLBRIEF_GITHUB_API_VERSION=2022-11-28

# MVP AI backend: PullBrief shells out to pi print mode.
# Install pi, run `pi`, then `/login` with your ChatGPT/Codex account before generating reports.
PULLBRIEF_PI_COMMAND=pi
# Optional: pin the pi model. If unset, pi uses the logged-in/default model from its own settings.
# PULLBRIEF_PI_MODEL=<pi-model-id>
# Optional: off|minimal|low|medium|high|xhigh, passed through to pi.
# PULLBRIEF_PI_THINKING=medium
PULLBRIEF_PI_TIMEOUT_MS=180000
PULLBRIEF_ALLOW_HEURISTIC_FALLBACK=true

# Set this to `heuristic` only for offline/local UI testing without pi.
# PULLBRIEF_AI_BACKEND=heuristic

# Keep patches bounded before sending context to pi.
PULLBRIEF_MAX_PATCH_CHARS=80000
PULLBRIEF_MAX_PATCH_CHARS_PER_FILE=8000

# Optional retention cleanup for raw patch text stored in report context.
PULLBRIEF_CONTEXT_RETENTION_DAYS=30
PULLBRIEF_CONTEXT_RETENTION_LIMIT=500
